# Local Wi‑Fi testing (optional): so phone scans reach your dev machine
# NEXT_PUBLIC_APP_URL=http://192.168.1.2:3000

# Vercel Production (recommended): your live site URL — QR codes always point here
# Set in Vercel → Project → Settings → Environment Variables → Production
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: table label on the QR card
# NEXT_PUBLIC_TABLE_NUMBER=5
