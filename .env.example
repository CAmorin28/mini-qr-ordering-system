# Supabase (required for database on Vercel — add in Project Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by API routes to insert orders (never expose publicly)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: override API base (usually leave empty on Vercel)
# NEXT_PUBLIC_API_URL=
