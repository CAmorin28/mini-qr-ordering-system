# MySQL (required for orders on production — add in Project Settings → Environment Variables)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=tablebite
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=tablebite

# Required for Aiven / cloud MySQL (download CA.pem from Aiven → paste PEM contents)
MYSQL_SSL=true
# MYSQL_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# Admin dashboard at /admin (server-only — never expose publicly)
ADMIN_PASSWORD=your-secure-admin-password

# Optional: separate signing secret for admin session cookies
# ADMIN_SESSION_SECRET=

# Local dev — desktop browser URL (do not set on Vercel unless needed).
# For phone testing on Wi‑Fi, open the app at http://YOUR_LAN_IP:3000 so QR codes scan correctly.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: table letter encoded in QR codes as /menu?table=A
# NEXT_PUBLIC_TABLE_LETTER=A

# Optional: separate API host (leave empty — same-origin /api on Vercel and `npm run dev`)
# NEXT_PUBLIC_API_URL=
