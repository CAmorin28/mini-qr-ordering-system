# Supabase (required for database on Vercel — add in Project Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by API routes to insert orders (never expose publicly)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard at /admin (server-only — never expose publicly)
ADMIN_PASSWORD=your-secure-admin-password

# Optional: separate signing secret for admin session cookies
# ADMIN_SESSION_SECRET=

# Local dev — one URL for the app, API, admin, and QR codes (do not set on Vercel unless needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: separate API host (leave empty — same-origin /api on Vercel and `npm run dev`)
# NEXT_PUBLIC_API_URL=
